<section class="contact-wrapper">
  <div class="contact-card">
    <h1>Send an Enquiry</h1>
    <p>
      Tell us what service you are interested in and we’ll help you work out the best next step.
    </p>

    <form method="POST" action="/contact" id="contactForm">
      <div class="mb-3">
        <label class="form-label">Name</label>
        <input name="name" class="form-control" placeholder="Enter your full name" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Email</label>
        <input name="email" type="email" class="form-control" placeholder="Enter your email address" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Service</label>
        <input
          name="service"
          class="form-control"
          placeholder="Example: Website Design"
          value="<%= service || '' %>"
        >
      </div>

      <div class="mb-3">
        <label class="form-label">Message</label>
        <textarea
          name="message"
          class="form-control"
          rows="5"
          placeholder="Tell us about your business, goal, budget, or problem you want solved"
        ></textarea>
      </div>

      <button class="btn btn-primary w-100">Send Message</button>
    </form>
  </div>
</section>