<div class="hero">
  <div class="hero-image"></div>

  <div class="hero-content">
    <h1>Scale Your Business With AI</h1>
    <p>
      Practical AI automation, digital systems, and growth-focused services designed to help small businesses capture leads, save time, and increase sales.
    </p>

    <div class="hero-actions mt-3">
      <a href="/contact?service=Free AI Growth Audit" class="btn btn-primary">Get a Free AI Growth Audit</a>
      <a href="/services" class="btn btn-secondary-custom">Browse Services</a>
    </div>
  </div>
</div>

<section class="home-section">
  <div class="section-heading">
    <h2 class="page-title">Built for businesses ready to scale</h2>
    <p class="page-subtitle">
      ServiceFlow helps turn manual tasks, missed leads, and scattered digital tools into clear systems that support growth.
    </p>
  </div>

  <div class="row mt-4">
    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <div class="card-body">
          <span class="service-category">Leads</span>
          <h3>Capture more opportunities</h3>
          <p>
            Build focused pages and enquiry paths that make it easier for visitors to take the next step.
          </p>
        </div>
      </div>
    </div>

    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <div class="card-body">
          <span class="service-category">Automation</span>
          <h3>Save time with smarter workflows</h3>
          <p>
            Reduce repetitive admin, improve follow-up, and create simple systems that keep your business moving.
          </p>
        </div>
      </div>
    </div>

    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <div class="card-body">
          <span class="service-category">Growth</span>
          <h3>Turn digital tools into sales support</h3>
          <p>
            Connect your website, services, and enquiry process around clear business outcomes.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="home-section">
  <div class="section-heading">
    <h2 class="page-title">Featured Services</h2>
    <p class="page-subtitle">
      Start with practical services that help your business look professional, generate leads, and automate the work behind the scenes.
    </p>
  </div>

  <div class="row mt-4">
    <% featuredServices.forEach(service => { %>
      <div class="col-md-6 mb-4">
        <div class="card service-card h-100">
          <div class="card-body">
            <span class="service-category"><%= service.category %></span>

            <h3><%= service.name %></h3>

            <p><%= service.description %></p>

            <p class="service-price">$<%= service.price %></p>

            <a href="/services/<%= service.slug %>" class="btn btn-primary">
              View Details
            </a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<section class="home-section">
  <div class="section-heading">
    <h2 class="page-title">How ServiceFlow helps</h2>
    <p class="page-subtitle">
      A simple path from business problem to practical digital system.
    </p>
  </div>

  <div class="process-grid mt-4">
    <div class="process-card">
      <span class="process-number">01</span>
      <h3>Review</h3>
      <p>
        Understand your business goal, current workflow, and where leads or time are being lost.
      </p>
    </div>

    <div class="process-card">
      <span class="process-number">02</span>
      <h3>Build</h3>
      <p>
        Create the right website, landing page, automation, or digital service around the outcome you need.
      </p>
    </div>

    <div class="process-card">
      <span class="process-number">03</span>
      <h3>Scale</h3>
      <p>
        Improve follow-up, reduce manual work, and give your business a stronger system for growth.
      </p>
    </div>
  </div>
</section>

<section class="home-section final-cta">
  <div class="card">
    <div class="card-body">
      <span class="service-category">AI Growth Audit</span>
      <h2 class="page-title">Not sure what your business needs first?</h2>
      <p class="page-subtitle">
        Start with a free AI growth audit and get a clearer view of where automation, better pages, or stronger digital systems could help increase sales.
      </p>

      <a href="/contact?service=Free AI Growth Audit" class="btn btn-primary mt-3">
        Get a Free AI Growth Audit
      </a>
    </div>
  </div>
</section>